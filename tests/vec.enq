import core::testing::*
import core::option::Option
import std::vec::Vec

struct Bucket {
    items: Vec[u32]
}

fn main() -> u32 {
    let mut v = Vec[u32]::new()
    if !assert(v.len() == 0_usize) {
        ret 1_u32
    }
    if !assert(v.is_empty()) {
        ret 1_u32
    }

    v = v.reserve(5_usize)
    if !assert(v.capacity() >= 5_usize) {
        ret 1_u32
    }

    v = v.push(3_u32)
    v = v.push(5_u32)
    v = v.push(8_u32)
    if !assert(v.len() == 3_usize) {
        ret 1_u32
    }

    match v.get(0_usize) {
        Option[u32]::Some(x) => {
            if !assert(x == 3_u32) {
                ret 1_u32
            }
        }
        Option[u32]::None => {
            ret 1_u32
        }
    }

    match v.get(2_usize) {
        Option[u32]::Some(x) => {
            if !assert(x == 8_u32) {
                ret 1_u32
            }
        }
        Option[u32]::None => {
            ret 1_u32
        }
    }

    match v.get(3_usize) {
        Option[u32]::Some(_) => {
            ret 1_u32
        }
        Option[u32]::None => {}
    }

    let bucket = Bucket{v}
    match bucket.items.get(1_usize) {
        Option[u32]::Some(x) => {
            if !assert(x == 5_u32) {
                ret 1_u32
            }
        }
        Option[u32]::None => {
            ret 1_u32
        }
    }

    ret 0_u32
}
