import core::testing::*
import std::path::Path

fn main() -> u32 {
    let p = Path::new("/tmp/example.tar.gz")
    if !assert(p.as_str() == "/tmp/example.tar.gz") {
        ret 1_u32
    }

    let child = p.join("child.txt")
    if !assert(child.as_str() == "/tmp/example.tar.gz/child.txt") {
        ret 1_u32
    }

    match p.name() {
        Some(name) => {
            if !assert(name == "example.tar.gz") {
                ret 1_u32
            }
        }
        None => {
            ret 1_u32
        }
    }

    match p.stem() {
        Some(stem) => {
            if !assert(stem == "example.tar") {
                ret 1_u32
            }
        }
        None => {
            ret 1_u32
        }
    }

    match p.suffix() {
        Some(suffix) => {
            if !assert(suffix == ".gz") {
                ret 1_u32
            }
        }
        None => {
            ret 1_u32
        }
    }

    let replaced = p.with_suffix(".txt")
    if !assert(replaced.as_str() == "/tmp/example.tar.txt") {
        ret 1_u32
    }

    let rel = Path::new("a//b///c")
    if !assert(rel.as_str() == "a/b/c") {
        ret 1_u32
    }

    ret 0_u32
}
